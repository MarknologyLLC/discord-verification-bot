# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=

# Guild (server) ID
GUILD_ID=

# Role ID for staff (can run /approve and /close)
STAFF_ROLE_ID=

# Channel ID where completed applications are logged (staff only)
LOG_CHANNEL_ID=

# Role ID granted on /approve
VERIFIED_ROLE_ID=

# Category ID where private ticket channels are created
PENDING_CATEGORY_ID=

# Local file where applications are stored (contains emails -- never commit)
DATA_FILE=creators.json
